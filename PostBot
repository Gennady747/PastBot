@router.message(PostCreation.waiting_schedule_time)
async def process_schedule(message: Message, state: FSMContext):
    data = await state.get_data()
    full_text = data["full_text"]
    photo_id = data.get("photo_id")
    uid = message.from_user.id
    settings = user_data[uid]["settings"]
    
    try:
        parts = message.text.rsplit(maxsplit=1)
        if len(parts) != 2:
            raise ValueError("Неверный формат")
        
        dt_str, channel_id = parts
        dt = datetime.strptime(dt_str, "%d.%m.%Y %H:%M")
        
        if dt < datetime.now():
            raise ValueError("Дата в прошлом")
        
        chat = await bot.get_chat(channel_id)
        member = await bot.get_chat_member(channel_id, bot.id)
        if not member.can_post_messages:
            raise ValueError("Нет прав")
        
        post_id = str(uuid.uuid4())[:8]
        scheduled_posts.append((
            dt, uid, channel_id, full_text, photo_id, post_id,
            settings["silent"], settings["protect"], settings["disable_preview"]
        ))
        
        user_data[uid]["stats"]["scheduled_active"] += 1
        
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📅 Запланированные", callback_data="scheduled")],
            [InlineKeyboardButton(text="← Меню", callback_data="back_main")]
        ])
        
        await message.answer(
            f"✅ Запланировано!\n📅 {dt.strftime('%d.%m.%Y %H:%M')}\n📢 {chat.title}",
            reply_markup=kb
        )
        await state.clear()
        
    except Exception as e:
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="← Назад", callback_data="schedule_post")]
        ])
        await message.answer(f"❌ Ошибка: {e}\n\nПроверьте формат!", reply_markup=kb)

