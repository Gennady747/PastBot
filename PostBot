@router.callback_query(F.data.in_(["choose_gallery", "random_gallery", "no_image"]))
async def choose_image(callback: CallbackQuery, state: FSMContext):
    uid = callback.from_user.id
    data = await state.get_data()
    main_text = data["main_text"]
    
    # Собираем блоки
    blocks_text = ""
    for i in range(1, 5):
        block = user_data[uid].get("blocks", {}).get(str(i), {})
        if block.get("content"):
            blocks_text += f"\n\n{block['content']}"
            user_data[uid]["stats"]["blocks_used"][str(i)] += 1
    
    full_text = main_text + blocks_text
    
    if callback.data == "choose_gallery":
        gallery = user_data[uid]["gallery"]
        if not gallery:
            await callback.answer("❌ Галерея пуста!", show_alert=True)
            return
        
        # Показываем первые 5 фото для выбора
        await callback.message.edit_text("🖼 Выбери фото из галереи:")
        
        for idx, photo_id in enumerate(gallery[:5]):
            kb = InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text=f"✅ Выбрать это фото", callback_data=f"select_photo_{idx}")]
            ])
            await callback.message.answer_photo(photo_id, reply_markup=kb)
        
        await state.update_data(full_text=full_text, available_photos=gallery[:5])
        
    elif callback.data == "random_gallery":
        import random
        gallery = user_data[uid]["gallery"]
        if gallery:
            photo_id = random.choice(gallery)
            await state.update_data(photo_id=photo_id, full_text=full_text)
            await show_preview(callback.message, state)
        else:
            await callback.answer("❌ Галерея пуста!", show_alert=True)
            return
            
    else:  # no_image
        await state.update_data(photo_id=None, full_text=full_text)
        await show_preview(callback.message, state, edit=False)
        return
    
    await callback.answer()

