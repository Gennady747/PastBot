            return
        
        if photo_id:
            await bot.send_photo(
                channel_id, photo_id, caption=full_text,
                disable_notification=settings["silent"],
                protect_content=settings["protect"]
            )
        else:
            await bot.send_message(
                channel_id, full_text,
                disable_notification=settings["silent"],
                protect_content=settings["protect"],
                disable_web_page_preview=settings["disable_preview"]
            )
        
        user_data[uid]["stats"]["posts"] += 1
        
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📝 Новый пост", callback_data="create_post")],
            [InlineKeyboardButton(text="← Меню", callback_data="back_main")]
        ])
        
        await message.answer(f"✅ Опубликовано в {chat.title}!", reply_markup=kb)
        await state.clear()
        
    except Exception as e:
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="🔄 Повторить", callback_data="publish_now")],
            [InlineKeyboardButton(text="← Назад", callback_data="back_to_preview")]
        ])
        await message.answer(f"❌ Ошибка: {e}", reply_markup=kb)

