# ====================== ПЛАНИРОВЩИК ======================
async def scheduler():
    while True:
        now = datetime.now()
        for task in list(scheduled_posts):
            if task[0] <= now:
                try:
                    _, uid, channel_id, text, photo_id, post_id, silent, protect, disable_preview = task
                    
                    # Проверяем подписку перед публикацией
                    if not await check_subscription(uid):
                        await bot.send_message(uid, "❌ Подписка истекла. Запланированный пост не опубликован.")
                        scheduled_posts.remove(task)
                        continue

                    if photo_id:
                        await bot.send_photo(
                            channel_id, 
                            photo_id, 
                            caption=text,
                            disable_notification=silent,
                            protect_content=protect
                        )
                    else:
                        await bot.send_message(
                            channel_id, 
                            text,
                            disable_notification=silent,
                            protect_content=protect,
                            disable_web_page_preview=disable_preview
                        )
                    
                    scheduled_posts.remove(task)
                    if uid in user_data:
                        user_data[uid]["stats"]["posts"] += 1
                        user_data[uid]["stats"]["scheduled_active"] = len([t for t in scheduled_posts if t[1] == uid])
                        
                except Exception as e:
                    logging.error(f"Ошибка публикации: {e}")
        await asyncio.sleep(30)

# ====================== ПРОВЕРКА ПОДПИСКИ ======================
async def check_subscription(uid: int) -> bool:
    if uid not in user_data:
        return False
    now = datetime.now()
    data = user_data[uid]
    if data.get("subscription_until") and data["subscription_until"] > now:
        return True
    if data.get("trial_until") and data["trial_until"] > now:
        return True
    return False

# ====================== СТАРТ ======================
@router.message(Command("start"))
async def cmd_start(message: Message, state: FSMContext, command: Command = None):
    uid = message.from_user.id
    args = command.args if command else None
    
    # Обработка реферальной ссылки
    if args and args.startswith("ref_"):
        referrer_id = int(args.split("_")[1])
        if referrer_id != uid and uid not in user_data:
            if referrer_id in user_data:
                user_data[referrer_id]["referrals"] += 1
                # +1 день подписки пригласившему
                if user_data[referrer_id].get("subscription_until"):
                    user_data[referrer_id]["subscription_until"] += timedelta(days=1)
                else:
                    user_data[referrer_id]["trial_until"] = max(
                        user_data[referrer_id].get("trial_until", datetime.now()),
                        datetime.now()
                    ) + timedelta(days=1)
                await bot.send_message(referrer_id, f"🎉 Новый реферал! +1 день к подписке.")

    if uid not in user_data:
        user_data[uid] = {
            "trial_until": datetime.now() + timedelta(days=5),
            "subscription_until": None,
            "channels": [],
            "blocks": {},
            "gallery": [],
            "settings": {"silent": False, "protect": False, "disable_preview": True, "auto_pin": False},
            "stats": {"posts": 0, "scheduled_active": 0, "blocks_used": {str(i): 0 for i in range(1, 5)}},
            "referrals": 0,
            "username": message.from_user.username or "Нет",
            "full_name": message.from_user.full_name
        }

    await message.answer(
        "👋 <b>Content Formatter Bot</b>\n\n"
        "Помогаю быстро и красиво оформлять посты для Telegram-каналов.\n\n"
        "🎁 <b>Первые 5 дней бесплатно!</b>\n\n"
        "Добавь меня администратором в канал с правом публикации сообщений.",
        reply_markup=main_menu()
    )
    await state.clear()

