from aiogram import Bot, Dispatcher, Router, F
from aiogram.client.default import DefaultBotProperties
from aiogram.enums import ParseMode
from aiogram.types import Message, CallbackQuery, InlineKeyboardMarkup, InlineKeyboardButton, LabeledPrice
from aiogram.filters import Command
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup
from aiogram.fsm.storage.memory import MemoryStorage
from datetime import datetime, timedelta
import asyncio
import logging

# ====================== ЗАГРУЗКА ТОКЕНА ИЗ .env ======================
from dotenv import load_dotenv
import os

load_dotenv()
BOT_TOKEN = os.getenv("BOT_TOKEN")

if not BOT_TOKEN:
    print("❌ Ошибка: BOT_TOKEN не найден в файле .env!")
    print("Создай файл .env рядом с bot.py и добавь туда:")
    print("BOT_TOKEN=123456:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
    exit(1)

# ====================== ИСПРАВЛЕННЫЙ BOT (aiogram 3.7+) ======================
bot = Bot(
    token=BOT_TOKEN,
    default=DefaultBotProperties(parse_mode=ParseMode.HTML)
)

storage = MemoryStorage()
dp = Dispatcher(storage=storage)
router = Router()
dp.include_router(router)

# ====================== FSM ======================
class BlockSetup(StatesGroup):
    waiting_content = State()

class PostCreation(StatesGroup):
    waiting_main_text = State()

class GalleryUpload(StatesGroup):
    waiting_photo = State()

# ====================== ДАННЫЕ ======================
user_data = {}          # uid → настройки пользователя
scheduled_posts = []    # список запланированных постов

# ====================== ГЛАВНОЕ МЕНЮ ======================
def main_menu():
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="👤 Мой профиль", callback_data="profile"),
         InlineKeyboardButton(text="⭐ Подписка", callback_data="subscription")],
        [InlineKeyboardButton(text="📋 Настройка блоков", callback_data="blocks_menu"),
         InlineKeyboardButton(text="🖼 Галерея картинок", callback_data="gallery")],
        [InlineKeyboardButton(text="📝 Создать пост", callback_data="create_post"),
         InlineKeyboardButton(text="📅 Запланированные посты", callback_data="scheduled")],
        [InlineKeyboardButton(text="📊 Статистика", callback_data="stats"),
         InlineKeyboardButton(text="👥 Партнёрка", callback_data="referral")],
        [InlineKeyboardButton(text="⚙️ Настройки", callback_data="settings"),
         InlineKeyboardButton(text="ℹ️ Как это работает", callback_data="info")],
        [InlineKeyboardButton(text="🆘 Поддержка", callback_data="support")]
    ])

# ====================== ФОНОВЫЙ ПЛАНИРОВЩИК ======================
async def scheduler():
    while True:
        now = datetime.now()
        for task in scheduled_posts[:]:
            publish_time, uid, channel_id, text, photo_id = task
            if publish_time <= now:
                try:
                    if photo_id:
                        await bot.send_photo(channel_id, photo_id, caption=text, parse_mode=ParseMode.HTML)
                    else:
                        await bot.send_message(channel_id, text, parse_mode=ParseMode.HTML)
                    scheduled_posts.remove(task)
                    if uid in user_data:
                        user_data[uid]["stats"]["posts"] += 1
                except Exception as e:
                    logging.error(f"Ошибка публикации: {e}")
        await asyncio.sleep(30)

# ====================== СТАРТ ======================
@router.message(Command("start"))
async def cmd_start(message: Message, state: FSMContext):
    uid = message.from_user.id
    if uid not in user_data:
        user_data[uid] = {
            "trial_until": datetime.now() + timedelta(days=5),
            "subscription_until": None,
            "channels": [],
            "blocks": {},
            "gallery": [],                    # список file_id фото
            "settings": {"silent": False, "protect": False, "disable_preview": True, "auto_pin": False},
            "stats": {"posts": 0},
            "referrals": 0
        }

    await message.answer(
        "👋 <b>Добро пожаловать в Content Formatter Bot!</b>\n\n"
        "Я помогаю авторам Telegram-каналов быстро и красиво оформлять посты.\n\n"
        "Что я умею:\n"
        "• Настраивать 4 постоянных блока (хэштеги, ссылки, текст, цитаты)\n"
        "• Хранить галерею твоих картинок\n"
        "• Создавать посты с автоматическим добавлением блоков\n"
        "• Публиковать сразу или запланировать на будущее\n"
        "• Показывать точный предпросмотр\n\n"
        "Добавь меня администратором в канал с правом отправки сообщений.\n\n"
        "Выбирай нужный раздел ниже 👇",
        reply_markup=main_menu()
    )
    await state.clear()

# ====================== ПРОФИЛЬ ======================
@router.callback_query(F.data == "profile")
async def show_profile(callback: CallbackQuery):
    uid = callback.from_user.id
    data = user_data.get(uid, {})
    now = datetime.now()

    if data.get("subscription_until") and data["subscription_until"] > now:
        status = f"✅ Подписка активна до {data['subscription_until'].strftime('%d.%m.%Y')}"
    elif data.get("trial_until") and data["trial_until"] > now:
        days = (data["trial_until"] - now).days
        status = f"🕒 Пробный период — {days} дней"
    else:
        status = "❌ Подписка неактивна"

    channels = "\n".join(f"• {ch}" for ch in data.get("channels", [])) or "Нет подключённых каналов"

    text = (f"👤 <b>Мой профиль</b>\n\n"
            f"Имя: <b>{callback.from_user.full_name}</b>\n"
            f"Подписка: {status}\n\n"
            f"<b>Каналы:</b>\n{channels}\n\n"
            f"Опубликовано постов: <b>{data['stats']['posts']}</b>")

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="🔄 Обновить", callback_data="refresh_profile")],
        [InlineKeyboardButton(text="← Главное меню", callback_data="back_main")]
    ])

    await callback.message.edit_text(text, reply_markup=kb)
    await callback.answer()

@router.callback_query(F.data == "refresh_profile")
async def refresh_profile(callback: CallbackQuery):
    await callback.answer("✅ Информация обновлена")
    await show_profile(callback)

# ====================== НАСТРОЙКА БЛОКОВ ======================
@router.callback_query(F.data == "blocks_menu")
async def blocks_menu(callback: CallbackQuery):
    text = ("📋 <b>Настройка блоков поста</b>\n\n"
            "Здесь ты настраиваешь 4 блока, которые будут автоматически добавляться к каждому посту.\n\n"
            "• Блок 1 — после основного текста\n"
            "• Блок 2 и 3 — в середине\n"
            "• Блок 4 — обычно в конце (хэштеги, ссылки)")
    
    kb = []
    for i in range(1, 5):
        b = user_data[callback.from_user.id].get("blocks", {}).get(str(i), {})
        status = b.get("type", "пусто")
        kb.append([InlineKeyboardButton(text=f"Блок {i} — {status}", callback_data=f"edit_block_{i}")])
    
    kb.append([InlineKeyboardButton(text="✅ Сохранить блоки", callback_data="save_blocks")])
    await callback.message.edit_text(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

# ====================== ГАЛЕРЕЯ ======================
@router.callback_query(F.data == "gallery")
async def show_gallery(callback: CallbackQuery):
    count = len(user_data[callback.from_user.id]["gallery"])
    text = f"🖼 <b>Галерея картинок</b>\n\nВ галерее: <b>{count}</b> фото\n\nЗагружай фото, которые хочешь использовать в постах."
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="📤 Загрузить фото", callback_data="upload_photo")],
        [InlineKeyboardButton(text="← Назад", callback_data="back_main")]
    ])
    await callback.message.edit_text(text, reply_markup=kb)
    await callback.answer()

@router.callback_query(F.data == "upload_photo")
async def start_upload(callback: CallbackQuery, state: FSMContext):
    await callback.message.edit_text("📤 Отправь мне фото (можно несколько). Когда закончишь — напиши /done")
    await state.set_state(GalleryUpload.waiting_photo)
    await callback.answer()

@router.message(GalleryUpload.waiting_photo)
async def receive_photo(message: Message, state: FSMContext):
    if message.photo:
        file_id = message.photo[-1].file_id
        user_data[message.from_user.id]["gallery"].append(file_id)
        await message.answer(f"✅ Фото добавлено! Всего: {len(user_data[message.from_user.id]['gallery'])}")
    else:
        await message.answer("Отправь фото.")

@router.message(Command("done"))
async def done_upload(message: Message, state: FSMContext):
    await state.clear()
    await message.answer("✅ Галерея обновлена!", reply_markup=main_menu())

# ====================== СОЗДАНИЕ ПОСТА ======================
@router.callback_query(F.data == "create_post")
async def create_post(callback: CallbackQuery, state: FSMContext):
    await callback.message.edit_text(
        "📝 <b>Создание поста</b>\n\nОтправь основной текст поста:",
        reply_markup=None
    )
    await state.set_state(PostCreation.waiting_main_text)
    await callback.answer()

@router.message(PostCreation.waiting_main_text)
async def get_main_text(message: Message, state: FSMContext):
    await state.update_data(main_text=message.text)
    await message.answer("Текст сохранён.\n\nТеперь выбери картинку или нажми /skip")
    # Здесь можно добавить выбор из галереи — пока упрощённо

# ====================== ОСТАЛЬНЫЕ РАЗДЕЛЫ ======================
@router.callback_query(F.data.in_(["subscription", "stats", "referral", "settings", "info", "support", "scheduled"]))
async def other_sections(callback: CallbackQuery):
    texts = {
        "subscription": "⭐ Здесь будет оплата через Telegram Stars",
        "stats": "📊 Статистика публикаций",
        "referral": "👥 Партнёрская программа — скоро",
        "settings": "⚙️ Настройки публикации",
        "info": "ℹ️ Подробная инструкция, как пользоваться ботом",
        "support": "🆘 Напиши @твой_юзернейм",
        "scheduled": "📅 Запланированные посты"
    }
    await callback.message.edit_text(texts.get(callback.data, "Раздел в разработке"), reply_markup=main_menu())
    await callback.answer()

@router.callback_query(F.data == "back_main")
async def back_main(callback: CallbackQuery):
    await callback.message.edit_text("Главное меню", reply_markup=main_menu())

# ====================== ЗАПУСК ======================
async def main():
    asyncio.create_task(scheduler())
    logging.basicConfig(level=logging.INFO)
    print("🚀 Бот успешно запущен на boothost.ru")
    print("Токен загружен из .env файла")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
