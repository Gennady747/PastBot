    await callback.answer()

@router.message(PostCreation.waiting_channel)
async def process_channel_or_time(message: Message, state: FSMContext):
    data = await state.get_data()
    action = data["action"]
    full_text = data["full_text"]
    photo_id = data.get("photo_id")
    uid = message.from_user.id
    settings = user_data[uid]["settings"]
    
    if action == "schedule":
        # Парсим дату
        try:
            dt = datetime.strptime(message.text, "%d.%m.%Y %H:%M")
            if dt < datetime.now():
                await message.answer("❌ Дата уже прошла! Введите будущую дату.")
                return
            
            # Сохраняем в планировщик
            post_id = str(uuid.uuid4())[:8]
            scheduled_posts.append((
                dt, uid, None, full_text, photo_id, post_id,
                settings["silent"], settings["protect"], settings["disable_preview"]
            ))
            
            user_data[uid]["stats"]["scheduled_active"] += 1
            
            await message.answer(
                f"✅ Пост запланирован!\n"
                f"📅 Дата: {dt.strftime('%d.%m.%Y %H:%M')}\n"
                f"🆔 ID: <code>{post_id}</code>",
                reply_markup=main_menu()
            )
            await state.clear()
            
        except ValueError:
            await message.answer("❌ Неверный формат! Используй: ДД.ММ.ГГГГ ЧЧ:ММ")
            return
    
    else:  # publish now
        channel_id = message.text.strip()
        try:
            # Проверяем права бота
            chat = await bot.get_chat(channel_id)
            member = await bot.get_chat_member(channel_id, bot.id)
            
            if not member.can_post_messages:
                await message.answer("❌ У бота нет прав на публикацию в этом канале!")
                return
            
            # Публикуем
            if photo_id:
                await bot.send_photo(
                    channel_id, 
                    photo_id, 
                    caption=full_text,
                    disable_notification=settings["silent"],
                    protect_content=settings["protect"]
                )
            else:
                await bot.send_message(
                    channel_id, 
                    full_text,
                    disable_notification=settings["silent"],
                    protect_content=settings["protect"],
                    disable_web_page_preview=settings["disable_preview"]
                )
            
            user_data[uid]["stats"]["posts"] += 1
            
            await message.answer(
                f"✅ Пост опубликован в {chat.title}!\n\n"
                f"📊 Всего опубликовано: {user_data[uid]['stats']['posts']}",
                reply_markup=main_menu()
            )
            await state.clear()
            
        except TelegramAPIError as e:
            await message.answer(f"❌ Ошибка: {e}\n\nПроверьте, что бот добавлен администратором в канал.")

# ====================== ЗАПЛАНИРОВАННЫЕ ПОСТЫ ======================
@router.callback_query(F.data == "scheduled")
async def show_scheduled(callback: CallbackQuery):
    if not await check_subscription(callback.from_user.id):
        await callback.answer("❌ Требуется активная подписка!", show_alert=True)
        return
    
    uid = callback.from_user.id
    user_posts = [t for t in scheduled_posts if t[1] == uid]
    
    if not user_posts:
        await callback.message.edit_text(
            "📅 <b>Запланированные посты</b>\n\n"
            "У вас нет запланированных постов.",
            reply_markup=main_menu()
        )
        await callback.answer()
        return
    
    text = "📅 <b>Запланированные посты:</b>\n\n"
    kb = []
    
    for task in sorted(user_posts, key=lambda x: x[0]):
        dt, _, _, post_text, _, post_id, _, _, _ = task
        preview = post_text[:30] + "..." if len(post_text) > 30 else post_text
        text += f"• <code>{post_id}</code> — {dt.strftime('%d.%m %H:%M')}: {preview}\n"
        kb.append([InlineKeyboardButton(
            text=f"🗑 Удалить {post_id}", 
            callback_data=f"delete_sched_{post_id}"
        )])
    
    kb.append([InlineKeyboardButton(text="← Назад", callback_data="back_main")])
    
    await callback.message.edit_text(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

@router.callback_query(F.data.startswith("delete_sched_"))
async def delete_scheduled(callback: CallbackQuery):
    post_id = callback.data.split("_")[-1]
    uid = callback.from_user.id
    
    for i, task in enumerate(scheduled_posts):
        if task[5] == post_id and task[1] == uid:
            scheduled_posts.pop(i)
            user_data[uid]["stats"]["scheduled_active"] -= 1
            await callback.answer("✅ Пост удалён!", show_alert=True)
            await show_scheduled(callback)
            return
    
    await callback.answer("❌ Пост не найден!", show_alert=True)

