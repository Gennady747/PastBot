from aiogram import Bot, Dispatcher, Router, F
from aiogram.types import Message, CallbackQuery, InlineKeyboardMarkup, InlineKeyboardButton, LabeledPrice, InputMediaPhoto
from aiogram.filters import Command
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup
from aiogram.fsm.storage.memory import MemoryStorage
from datetime import datetime, timedelta
import asyncio
import logging
import random

# ====================== ТОКЕН ======================
from dotenv import load_dotenv
import os

load_dotenv()
BOT_TOKEN = os.getenv("BOT_TOKEN")
if not BOT_TOKEN:
    print("❌ BOT_TOKEN не найден в .env!")
    exit(1)

bot = Bot(token=BOT_TOKEN, parse_mode="HTML")
storage = MemoryStorage()
dp = Dispatcher(storage=storage)
router = Router()
dp.include_router(router)

# ====================== FSM ======================
class BlockSetup(StatesGroup):
    waiting_content = State()

class PostCreation(StatesGroup):
    waiting_main_text = State()
    waiting_media = State()
    waiting_schedule = State()

class GalleryUpload(StatesGroup):
    waiting_photo = State()

# ====================== ДАННЫЕ ======================
user_data = {}          # основные данные пользователя
scheduled_posts = []    # список отложенных постов: (publish_time, user_id, chat_id, text, media_id, blocks)

def main_menu():
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="👤 Мой профиль", callback_data="profile"),
         InlineKeyboardButton(text="⭐ Подписка", callback_data="subscription")],
        [InlineKeyboardButton(text="📋 Настройка блоков", callback_data="blocks_menu"),
         InlineKeyboardButton(text="🖼 Галерея", callback_data="gallery")],
        [InlineKeyboardButton(text="📝 Создать пост", callback_data="create_post"),
         InlineKeyboardButton(text="📅 Запланированные посты", callback_data="scheduled")],
        [InlineKeyboardButton(text="📊 Статистика", callback_data="stats"),
         InlineKeyboardButton(text="👥 Партнёрка", callback_data="referral")],
        [InlineKeyboardButton(text="⚙️ Настройки", callback_data="settings"),
         InlineKeyboardButton(text="ℹ️ Как это работает", callback_data="info")],
        [InlineKeyboardButton(text="🆘 Поддержка", callback_data="support")]
    ])

# ====================== ФОНОВЫЙ ПЛАНИРОВЩИК ======================
async def scheduler():
    while True:
        now = datetime.now()
        for task in scheduled_posts[:]:
            if task[0] <= now:
                publish_time, uid, channel, text, media_id, blocks = task
                try:
                    if media_id:
                        await bot.send_photo(channel, media_id, caption=text, parse_mode="HTML")
                    else:
                        await bot.send_message(channel, text, parse_mode="HTML")
                    scheduled_posts.remove(task)
                    user_data[uid]["stats"]["posts"] += 1
                except Exception as e:
                    print(f"Ошибка публикации: {e}")
        await asyncio.sleep(30)  # проверяем каждые 30 секунд

# ====================== СТАРТ ======================
@router.message(Command("start"))
async def cmd_start(message: Message, state: FSMContext):
    uid = message.from_user.id
    if uid not in user_data:
        user_data[uid] = {
            "trial_until": datetime.now() + timedelta(days=5),
            "subscription_until": None,
            "channels": [],
            "blocks": {},
            "gallery": [],          # список file_id фотографий
            "settings": {"silent": False, "protect": False, "disable_preview": True, "auto_pin": False},
            "stats": {"posts": 0},
            "referrals": 0
        }

    await message.answer(
        "👋 <b>Content Formatter Bot</b>\n\n"
        "Я полностью автоматизирую оформление и публикацию постов в твои каналы.\n\n"
        "Что ты можешь делать:\n"
        "• Настраивать 4 постоянных блока (хэштеги, ссылки, цитаты и т.д.)\n"
        "• Создавать галерею картинок и использовать их в постах (или рандомно)\n"
        "• Публиковать посты сразу или запланировать на любое время\n"
        "• Получать красивый предпросмотр перед публикацией\n\n"
        "Добавь меня администратором в канал и начинай!",
        reply_markup=main_menu()
    )
    await state.clear()

# ====================== ГАЛЕРЕЯ ======================
@router.callback_query(F.data == "gallery")
async def show_gallery(callback: CallbackQuery):
    uid = callback.from_user.id
    gallery = user_data[uid]["gallery"]
    count = len(gallery)
    text = (f"🖼 <b>Твоя галерея</b>\n\n"
            f"В галерее сейчас <b>{count}</b> фото.\n\n"
            "Что хочешь сделать?\n"
            "• Загрузить новые фото\n"
            "• Посмотреть все фото\n"
            "• Очистить галерею")
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="📤 Загрузить фото", callback_data="upload_photo")],
        [InlineKeyboardButton(text="👁 Посмотреть галерею", callback_data="view_gallery")],
        [InlineKeyboardButton(text="🗑 Очистить галерею", callback_data="clear_gallery")],
        [InlineKeyboardButton(text="← Главное меню", callback_data="back_main")]
    ])
    await callback.message.edit_text(text, reply_markup=kb)
    await callback.answer()

@router.callback_query(F.data == "upload_photo")
async def upload_photo(callback: CallbackQuery, state: FSMContext):
    await callback.message.edit_text("📤 Отправь мне фото (можно несколько подряд). Когда закончишь — нажми /done")
    await state.set_state(GalleryUpload.waiting_photo)
    await callback.answer()

@router.message(GalleryUpload.waiting_photo)
async def receive_photo(message: Message, state: FSMContext):
    if message.photo:
        file_id = message.photo[-1].file_id
        user_data[message.from_user.id]["gallery"].append(file_id)
        await message.answer(f"✅ Фото добавлено в галерею ({len(user_data[message.from_user.id]['gallery'])} шт.)")
    else:
        await message.answer("Это не фото. Отправь фото.")

@router.message(Command("done"))
async def done_gallery(message: Message, state: FSMContext):
    await state.clear()
    await message.answer("✅ Галерея обновлена!", reply_markup=main_menu())

# ====================== СОЗДАНИЕ ПОСТА (с галереей и планированием) ======================
@router.callback_query(F.data == "create_post")
async def create_post(callback: CallbackQuery, state: FSMContext):
    text = ("📝 <b>Создание поста</b>\n\n"
            "1. Отправь основной текст поста\n"
            "2. Я предложу выбрать картинку из галереи или загрузить новую\n"
            "3. Добавлю твои блоки (хэштеги, ссылки, цитаты)\n"
            "4. Покажу предпросмотр\n"
            "5. Ты сможешь опубликовать сразу или запланировать\n\n"
            "Отправь основной текст поста:")
    await callback.message.edit_text(text)
    await state.set_state(PostCreation.waiting_main_text)
    await callback.answer()

@router.message(PostCreation.waiting_main_text)
async def get_main_text(message: Message, state: FSMContext):
    await state.update_data(main_text=message.text)
    uid = message.from_user.id
    gallery_size = len(user_data[uid]["gallery"])
    
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="🖼 Выбрать из галереи", callback_data="use_gallery")],
        [InlineKeyboardButton(text="🎲 Рандом из галереи", callback_data="random_gallery")],
        [InlineKeyboardButton(text="📤 Загрузить новое фото", callback_data="upload_new")],
        [InlineKeyboardButton(text="Без картинки", callback_data="no_photo")]
    ])
    
    await message.answer(f"Отлично! Выбери картинку для поста.\nВ твоей галерее сейчас {gallery_size} фото.", reply_markup=kb)
    await state.set_state(PostCreation.waiting_media)

# (дальше обработчики use_gallery, random_gallery и т.д. можно расширить — я оставил место)

# ====================== ПЛАНИРОВАНИЕ ======================
# После предпросмотра будет кнопка «Запланировать»

@router.callback_query(F.data == "scheduled")
async def show_scheduled(callback: CallbackQuery):
    await callback.answer("Пока здесь будут показаны все запланированные посты (в разработке)", show_alert=True)

# ====================== ЗАПУСК ======================
async def main():
    asyncio.create_task(scheduler())   # запускаем планировщик
    logging.basicConfig(level=logging.INFO)
    print("🚀 Полноценный бот с галереей и планированием запущен!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
