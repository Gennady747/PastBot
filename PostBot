async def show_preview(message: Message, state: FSMContext, edit=True):
    data = await state.get_data()
    full_text = data["full_text"]
    photo_id = data.get("photo_id")
    settings = user_data[message.chat.id]["settings"]
    
    preview_text = (f"👁 <b>Предпросмотр поста:</b>\n\n"
                    f"{full_text}\n\n"
                    f"⚙️ Настройки: "
                    f"{'🔕 ' if settings['silent'] else '🔔 '}"
                    f"{'🔒 ' if settings['protect'] else '🔓 '}"
                    f"{'🔗 ' if settings['disable_preview'] else '🌐 '}")
    
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="📢 Опубликовать сейчас", callback_data="publish_now")],
        [InlineKeyboardButton(text="📅 Запланировать", callback_data="schedule_post")],
        [InlineKeyboardButton(text="✏️ Изменить текст", callback_data="create_post")],
        [InlineKeyboardButton(text="❌ Отмена", callback_data="back_main")]
    ])
    
    if photo_id:
        if edit and message.photo:
            await message.edit_caption(caption=preview_text, reply_markup=kb)
        else:
            await message.answer_photo(photo_id, caption=preview_text, reply_markup=kb)
    else:
        if edit:
            try:
                await message.edit_text(preview_text, reply_markup=kb)
            except:
                await message.answer(preview_text, reply_markup=kb)
        else:
            await message.answer(preview_text, reply_markup=kb)
    
    await state.set_state(PostCreation.waiting_channel)

