@router.callback_query(F.data == "scheduled")
async def show_scheduled(callback: CallbackQuery):
    if not await check_subscription(callback.from_user.id):
        await callback.answer("❌ Требуется подписка!", show_alert=True)
        return
    
    uid = callback.from_user.id
    user_posts = [t for t in scheduled_posts if t[1] == uid]
    
    if not user_posts:
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="📝 Создать", callback_data="create_post")],
            [InlineKeyboardButton(text="← Назад", callback_data="back_main")]
        ])
        await callback.message.edit_text("📅 Нет запланированных постов.", reply_markup=kb)
        return
    
    text = "📅 <b>Запланированные:</b>\n\n"
    kb = []
    
    for task in sorted(user_posts, key=lambda x: x[0]):
        dt, _, _, post_text, _, post_id, _, _, _ = task
        preview = post_text[:25] + "..." if len(post_text) > 25 else post_text
        text += f"• <code>{post_id}</code> {dt.strftime('%d.%m %H:%M')}: {preview}\n"
        kb.append([InlineKeyboardButton(text=f"🗑 {post_id}", callback_data=f"del_{post_id}")])
    
    kb.append([InlineKeyboardButton(text="← Назад", callback_data="back_main")])
    await callback.message.edit_text(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

@router.callback_query(F.data.startswith("del_"))
async def delete_scheduled(callback: CallbackQuery):
    post_id = callback.data.split("_")[1]
    uid = callback.from_user.id
    
    for i, task in enumerate(scheduled_posts):
        if task[5] == post_id and task[1] == uid:
            scheduled_posts.pop(i)
            user_data[uid]["stats"]["scheduled_active"] -= 1
            await callback.answer("✅ Удалено!", show_alert=True)
            await show_scheduled(callback)
            return
    
    await callback.answer("❌ Не найдено!", show_alert=True)

